#ALIAS {makepouch3} {#NOP UNSUPPORTED: #ex ("#alias ppa=put all.\$1 "+$petalpouch)}
#ALIAS {makepouch4} {#NOP UNSUPPORTED: #ex ("#alias gp=get \$1 "+$petalpouch)}
