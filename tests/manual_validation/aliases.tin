///  Still working on this - multi-sack management. 'lsa' will look in an weigh all sacks, useful for herbloot storage IMHO
#($p_SACKLET_0 = "a")
#($p_SACKLET_1 = "b")
#($p_SACKLET_2 = "c")
#VARIABLE {p_sacknum} {0}
#(" ["+$p_SACKLET_$p_sacknum+"]")
#CLASS {sackid} {OPEN}
#ACTION {^sack (%1)} {#IF {$p_sacknum == "0"} {#LINE PRINT}; #ELSE {#SHOWME {""}; #SHOWME {"$p_ULINEContents of $p_sacknum.sack (%1)$p_NORM"}}}
#CLASS {sackid} {CLOSE}
#CLASS {sackgag} {OPEN}
#ACTION {It is a large sack.} {#LINE GAG}
#CLASS {sackgag} {CLOSE}
