#CLASS {converted} {OPEN}
#NOP --- POWWOW COMPATIBILITY LAYER ---
#VARIABLE {powwow_at_lines} {24}
#VARIABLE {powwow_at_mem} {0}
#VARIABLE {powwow_at_buffer} {0}
#FORMAT {powwow_start_time} {%T}
#FUNCTION {powwow_timer} {#FORMAT {now} {%T};#MATH {result} {($now - $powwow_start_time) * 1000}}
#FUNCTION {powwow_rand} {#MATH {result} {1d%1 - 1}}
#FUNCTION {powwow_char_length} {#FORMAT {result} {%x} {%1}}
#FUNCTION {powwow_search} {#FORMAT {result} {%p} {%2} {%1}}
#FUNCTION {powwow_word_count} {#LIST {p_words} {TOKENIZE} {%1}; #LIST {p_words} {FILTER} {{[^ ]+}}; #LIST {p_words} {SIZE} {result}}
#FUNCTION {powwow_word} {#LIST {p_words} {TOKENIZE} {%1}; #LIST {p_words} {FILTER} {{[^ ]+}}; #LIST {p_words} {GET} {%2} {result}}
#FUNCTION {powwow_word_slice_to_end} {#LIST {p_words} {TOKENIZE} {%1}; #LIST {p_words} {FILTER} {{[^ ]+}}; #LIST {p_words} {GET} {%2..-1} {p_slice}; #LIST {p_slice} {COLLAPSE} {result} { }}
#FUNCTION {powwow_word_slice_from_start} {#LIST {p_words} {TOKENIZE} {%1}; #LIST {p_words} {FILTER} {{[^ ]+}}; #LIST {p_words} {GET} {1..%2} {p_slice}; #LIST {p_slice} {COLLAPSE} {result} { }}
#FUNCTION {powwow_first_char_ascii} {#FORMAT {result} {%a} {%1}}
#FUNCTION {powwow_to_number} {#MATH {result} {%1}}
#ALIAS {aule} {'by the might of Aule I command thee to open'}
///  Moods
#ALIAS {csq} {cha spell q}
#ALIAS {csf} {cha spell f}
#ALIAS {csn} {cha spell n}
#ALIAS {csc} {cha spell c}
#ALIAS {cst} {cha spell t}
#ALIAS {cma} {cha moo agg}
#ALIAS {cmb} {cha moo brave}
#ALIAS {cmn} {cha moo normal}
#ALIAS {cmp} {cha moo prudent}
#ALIAS {cmw} {cha moo wimpy}
#ALIAS {can} {cha alert n}
#ALIAS {cac} {cha alert c}
#ALIAS {caa} {cha alert a}
#ALIAS {cav} {cha alert v}
#ALIAS {cap} {cha alert p}
///  General
#ALIAS {voidoff} {#CLASS {void} {OPEN}}
#ALIAS {voidon} {#CLASS {void} {KILL}}
#ALIAS {w0} {cha wimp 0}
#ALIAS {w1} {cha wimp 10}
#ALIAS {w2} {cha wimp 20}
#ALIAS {w3} {cha wimp 30}
#ALIAS {w5} {cha wimp 50}
#ALIAS {w8} {cha wimp 80}
#ALIAS {w10} {cha wimp 100}
#ALIAS {w15} {cha wimp 150}
#ALIAS {w20} {cha wimp 200}
#ALIAS {wl} {weather local}
#ALIAS {x} {exa %1}
#ALIAS {xc} {#IF {@powwow_first_char_ascii{%%0}} {exam %0.corpse}}
#ELSE {exam corpse}
#ALIAS {xs} {#IF {@powwow_first_char_ascii{%%0}} {exam %0.skeleton}}
#ELSE {exam skeleton}
#ALIAS {ee} {scout east}
#ALIAS {dd} {scout down}
#ALIAS {ww} {scout west}
#ALIAS {uu} {scout up}
#ALIAS {nn} {scout north}
#ALIAS {ss} {scout south}
#ACTION {^You are awakened by} {#LINE PRINT; stand}
#ALIAS {ws} {wake; stand}
#ALIAS {wa} {ws}
#ALIAS {da} {drop all.%1}
#ALIAS {dam} {eat meat; eat meat; drop all.meat}
#ALIAS {ban} {bandage %1}
#ALIAS {bcx} {"butcher "+$(1)+".corpse"}
#ALIAS {bc} {gb knife; #IF {@powwow_first_char_ascii{%%1}} {butcher %1.corpse}; #ELSE {butcher corpse}; pb knife}
#ALIAS {bca} {gb knife; butcher 1.corpse; butcher 2.corpse; butcher 3.corpse; butcher 4.corpse; butcher 5.corpse; pb knife}
#ALIAS {Xbcaa} {gb knife; #(@(0)=1); #WHILE {@(0)<10} {"bcx "+(@powwow_to_number{@})(0); #(@(0)++)}; pb knife}
#ALIAS {bcaa} {gb knife; #(@(0)=1); #WHILE {@(0)<10} {bcx $powwow_at[0]; #(@(0)++)}; pb knife}
#ALIAS {bdg} {bca; dam; g2a}
#ALIAS {pipe} {gb pipe; wield pipe; rest; smoke; stand; wm; pb pipe}
#CLASS {server1} {OPEN}
#ACTION {^###} {#SHOWME {"$p_BKBLUE$p_YELLOW     ---+++%0 ###+++---$p_NORM"}}
#CLASS {server1} {CLOSE}
#ALIAS {dw} {drink water}
#ALIAS {ds} {drink flagon}
#ALIAS {pws} {pour water flagon}
/// Uses food/water stashed in satchel/saddlebag on mount
#ALIAS {pwg} {utm; gta goblet; pour water 1.goblet; pour water 1.goblet; pta goblet; gm}
#ALIAS {dg} {utm; gt goblet; drink goblet; pt goblet; gm}
#ALIAS {pwf} {utm; gt flagon; pour water flagon; pt flagon; gm}
#ALIAS {df} {utm; gt flagon; drink flagon; pt flagon; gm}
#ALIAS {pwc} {gb goblet; pour water goblet; pb goblet}
#ALIAS {dc} {gb goblet; drink goblet; pb goblet}
#ALIAS {eb} {utm; gt bannock; eat bannock; gm}
/// For use with small elven bag
#ALIAS {eeb} {gb small; #IF {$powwow_at_stunpouches} {g lembas 2.small}; #ELSE {g lembas small}; eat lembas; pb small}
#ALIAS {deb} {gb small; #IF {$powwow_at_stunpouches} {g cup 2.small; drink cup; put cup 2.small}; #ELSE {g cup small; drink cup; put cup small}; pb small}
#ALIAS {ga} {get all.%1}
#ALIAS {gaa} {get all.%1 from all}
#ALIAS {ga1} {get %1 from all}
#ALIAS {gac} {get all.%1 from all.corpse}
#ALIAS {gas} {gf all.skeleton}
#ALIAS {gf} {get all from %1}
#ALIAS {gfa} {gf 1.rack; gf 2.rack; gf 3.rack; gf 4.rack; gf 5.rack; gf 1.peg; gf 2.peg; gf 3.peg}
///  'gak' is get all key, including from pouches
#ALIAS {gak} {ga key; gac key; gac pouch; get all.key from all.pouch; da pouch; pkey all.key}
///  'gmac' is get all.metal all.corpse, except a bit broader - possibly too broad still (stweapon for instance are usually low in value)
#ALIAS {gmac} {gac chain; gac metal; gac scale; gac cweapon; gac pweapon; gac tweapon; gac sweapon; gac stweapon}
#ALIAS {r} {get all.arrow; get all.arrow all.corpse; put all.arrow quiver}
///  Aliases for killing and charmies
///  mta <target> sets your target, cta <target> sets charmies'. ta <target> puts you both on the same. You can set target when not in the room, eg. 3.bear
///  Some (`, oka, b, spells etc) will automatically use target if set (ta <target> or mta <target>), unless you specify something else
#ALIAS {Xb} {#IF {@powwow_first_char_ascii{$}(1)} {bash %1}; #ELSE {"bash $p_mtarget"}}
#ALIAS {Xbd} {#IF {@powwow_first_char_ascii{$}(1)} {bash dis %1}; #ELSE {"bash dis $p_mtarget"}}
#ALIAS {b} {bash %1}
#ALIAS {bd} {bash dis %1}
#ALIAS {`} {#IF {@powwow_first_char_ascii{$}(1)} {shoot %1}; #ELSE {"shoot $p_mtarget"}}
#ALIAS {k} {{ #if (*$(1)) kill %1; #else #send ("kill "+$p_mtarget) }}
#ALIAS {B} {{ #if (*$(1)) backstab %1; #else #send ("backstab "+$p_mtarget) }}
#ALIAS {F} {flush quick}
#ALIAS {R} {rescue %1}
#ALIAS {p} {protect %1}
#ALIAS {ka} {{ #if (*$(1)) kill %1; #else #send ("kill "+$p_mtarget) }; ofa}
#ALIAS {ob} {order bashera bash %0}
#ALIAS {of} {order followers %0}
#ALIAS {off} {order followers flee}
#ALIAS {ff} {off; flee}
#ALIAS {ofa} {order followers assist; #IF {$powwow_at_folautobash} {ob}}
#ALIAS {ofb} {order followers bash}
#ALIAS {ofk} {order followers kill %0}
#ALIAS {ofat} {#NOP UNSUPPORTED: #ex ("of assist "+$tank); #IF {$powwow_at_folautobash} {ob}}
#ALIAS {ofp} {#IF {@powwow_first_char_ascii{$}(1)} {order followers protect %1}; #ELSE {"order followers protect $p_name"}}
#ALIAS {ofr} {#IF {@powwow_first_char_ascii{$}(1)} {order followers rescue %1}; #ELSE {"order followers rescue $p_name"}}
#ALIAS {oka} {{ #if (*$(1)) order tanka kill %1; #else #send ("order tanka kill "+$p_ctarget) }; assist; ofat}
#ALIAS {revoka} {{ #if (*$(1)) {rev %1; order tanka kill %1}; #else #ex ("rev "+$p_ctarget+"; order tanka kill "+$p_ctarget) }; assist; ofat}
#ALIAS {revotk} {{ #if (*$(1)) {rev %1; order tanka kill %1}; #else #ex ("rev "+$p_ctarget+";order tanka kill "+$p_ctarget) }}
#ALIAS {ock} {{ #if (*$(1)) { order tanka kill %1}; #else {#send ("order tanka kill "+$p_ctarget)}; ofat }}
#ALIAS {revock} {{ #if (*$(1)) {rev %1; order tanka kill %1}; #else { #send ("rev "+$p_ctarget+";order tanka kill "+$p_ctarget)}; ofat }}
#ALIAS {ot} {order tanka %0}
#ALIAS {otk} {{ #if (*$(1)) order tanka kill %1; #else #send ("order tanka kill "+$p_ctarget) }}
#ALIAS {otsl} {ot sleep; "order tanka act waiting for its mistress"}
#ALIAS {ota} {order tanka assist %0}
#ALIAS {otr} {order tanka resc %0}
#ALIAS {op} {order parrya %0}
#ALIAS {opk} {order parrya kill %0}
#ALIAS {opa} {order parrya assist %0}
#ALIAS {opr} {order parrya resc}
#ALIAS {opb} {order parryb %0}
#ALIAS {opbk} {order parryb kill %0}
#ALIAS {opba} {order parryb assist %0}
#ALIAS {opc} {order parryc %0}
#ALIAS {opck} {order parryc kill %0}
#ALIAS {opca} {order parryc assist %0}
#ALIAS {opd} {order parryd %0}
#ALIAS {opdk} {order parryd kill %0}
#ALIAS {opda} {order parryd assist %0}
#ALIAS {opka} {"order parrya kill 1.$p_ctarget"; "order parryb kill 2.$p_ctarget"; "order parryc kill 3.$p_ctarget"; "order parryd kill 4.$p_ctarget"}
#ALIAS {otka} {"order tanka kill 1.$p_ctarget"; "order tankb kill 2.$p_ctarget"; "order tankc kill 3.$p_ctarget"; "order tankd kill 4.$p_ctarget"}
#ALIAS {ofsl} {of sleep; "order followers act , waiting for its mistress"}
#ALIAS {ofsln} {of sleep; "order followers act , waiting for $p_name"}
#ALIAS {ofwa} {of wake; of stand}
#ALIAS {aa} {assist; ofa}
#ALIAS {fa} {tell familiar %0}
#ALIAS {fal} {tell familiar leave; fwatchoff}
#ALIAS {F} {tell familiar %0}
#ALIAS {L} {tell familiar look %0}
#ALIAS {N} {tell familiar n; L}
#ALIAS {E} {tell familiar e; L}
#ALIAS {S} {tell familiar s; L}
#ALIAS {W} {tell familiar w; L}
#ALIAS {U} {tell familiar u; L}
#ALIAS {D} {tell familiar d; L}
#VARIABLE {p_abc} {abcdefghijklmnopqrstuvwxyz}
#VARIABLE {p_tank} {mother}
#ALIAS {tank} {_newcharmie tank %1}
#ALIAS {parry} {_newcharmie parry %1}
#ALIAS {basher} {_newcharmie basher %1; #VARIABLE {powwow_at_folautobash} {1}}
#ALIAS {_newcharmie} {#(@%1s+=1); #VARIABLE {p_new$1} {%1$p_abc".char[@%1s]}; "label %2 $p_new%1"; "group $p_new%1"; #NOP UNSUPPORTED: #ex ("message $2 ("+$new$1+") is now a $1."); #NOP UNSUPPORTED: #ex ("_charmietimer "+$new$1)}
#ALIAS {swapt} {order tanka protect self; label tanka tankx; label tankb tanka; label tankx tankb; "order tanka protect $p_name"}
/// TODO: Make based on what we actually have
#ALIAS {grf} {gr tanka; gr parrya; gr parryb}
///  All target - make us all aim at the same
#ALIAS {ta} {mta %1; cta %1}
///  My target - what I'm aiming at
#($p_mtarget = "")
#ALIAS {mta} {#VARIABLE {p_mtarget} {%1}; #IF {"%1" == ""} {#VARIABLE {p_mtarget} {}; #SHOWME {"$p_BLUE   My target cleared.$p_NORM"}}; #ELSE {#SHOWME {"$p_BLUE   My target  --> $p_BOLD$p_mtarget$p_NORM"}}}
///  Charmie target - what we're sicking the charmies on
#($p_ctarget = "")
#ALIAS {cta} {#VARIABLE {p_ctarget} {%1}; #IF {"%1" == ""} {#VARIABLE {p_mtarget} {}; #SHOWME {"$p_BLUE   Charmies' target cleared.$p_NORM"}}; #ELSE {#SHOWME {"$p_BLUE   Charmies' target  --> $p_BOLD$p_ctarget$p_NORM"}}}
#ALIAS {xt} {"exa $p_mtarget"}
///  Repeatable actions on same-named targets
///   - For example, 'ta statue' then 'setq vbt' before entering room. On entering type 1<enter>, 2<enter> etc for 'cast thoro 'blindness' 1.statue, then 2. etc
#VARIABLE {p_qspell} {vb}
#VARIABLE {p_nspell} {vd}
#ALIAS {setq} {#VARIABLE {p_qspell} {%1}; #NOP UNSUPPORTED: #ex 1}
#ALIAS {setn} {#VARIABLE {p_nspell} {%1}; #NOP UNSUPPORTED: #ex 2}
#MATH {p_qact} {$p_qspell}
#ALIAS {1} {#MATH {p_qact} {$p_qspell}; #NOP UNSUPPORTED: #ex ("message Quick-action now BLIND ("+$qspell+")")}
#ALIAS {2} {#MATH {p_qact} {$p_nspell}; #NOP UNSUPPORTED: #ex ("message Quick-action now NUKE ("+$nspell+")")}
#ALIAS {3} {#VARIABLE {p_qact} {ock}; #NOP UNSUPPORTED: #ex ("message Quick-action now CHAMIE ATTACK (ock)")}
#ALIAS {4} {#VARIABLE {p_qact} {kill}; #NOP UNSUPPORTED: #ex ("message Quick-action now KILL")}
#ALIAS {5} {-}
#ALIAS {6} {[}
#ALIAS {7} {]}
#ALIAS {0} {#VARIABLE {p_qact} {cht}; #NOP UNSUPPORTED: #ex ("message Quick-action now CHARM")}
#ALIAS {-} {#VARIABLE {p_qact} {kill}; #NOP UNSUPPORTED: #ex ("message Quick-action now PK-KILL (charmie attack + nuke)")}
#ALIAS {]} {#VARIABLE {p_qact} {bash dis}; #NOP UNSUPPORTED: #ex ("message Quick-action now BASH-DISENGAGE")}
#ALIAS {[} {#VARIABLE {p_qact} {bash}; #NOP UNSUPPORTED: #ex ("message Quick-action now BASH")}
#NOP ORIGINAL BIND LABEL: f1
#MACRO {^[OP} {#NOP UNSUPPORTED: #ex ($qact+" 1."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f2
#MACRO {^[OQ} {#NOP UNSUPPORTED: #ex ($qact+" 2."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f3
#MACRO {^[OR} {#NOP UNSUPPORTED: #ex ($qact+" 3."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f4
#MACRO {^[OS} {#NOP UNSUPPORTED: #ex ($qact+" 4."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f5
#MACRO {^[[15~} {#NOP UNSUPPORTED: #ex ($qact+" 5."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f6
#MACRO {^[[17~} {#NOP UNSUPPORTED: #ex ($qact+" 6."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f7
#MACRO {^[[18~} {#NOP UNSUPPORTED: #ex ($qact+" 7."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f8
#MACRO {^[[19~} {#NOP UNSUPPORTED: #ex ($qact+" 8."+$mtarget)}
#NOP ORIGINAL BIND LABEL: f9
#MACRO {^[[20~} {#NOP UNSUPPORTED: #ex ($qact+" 9."+$mtarget)}
/// Qick PK targettting
#ALIAS {tb} {ta *bear*}
#ALIAS {td} {ta *dwarf*}
#ALIAS {te} {ta *elf*}
#ALIAS {th} {ta *hobbit*}
#ALIAS {tm} {ta *man*}
#ALIAS {to} {ta *orc*}
#ALIAS {tt} {ta *troll*}
///  Some quick aliases for PK. I'm clueless at it so probably make your own!
#ALIAS {km} {k *man*}
#ALIAS {ko} {k *orc*}
#ALIAS {kt} {k *troll*}
#ALIAS {cm} {ock *man*}
#ALIAS {co} {ock *orc*}
#ALIAS {ct} {ock *troll*}
#ALIAS {qm} {cast fast 'dispel evil' *man*}
#ALIAS {qo} {cast fast 'dispel evil' *orc*}
#ALIAS {qt} {cast fast 'dispel evil' *troll*}
#ALIAS {K} {#IF {$p_ctarget != ""} {#NOP UNSUPPORTED: #ex ("of kill "+$ctarget)}; dispel fast %1}
///  Mounts - some of Kate's custom setup in here!
#ALIAS {s1} {saddle mine}
#ALIAS {s2} {saddle mineb}
#ALIAS {usal} {unsaddle %1 all}
#ALIAS {u1} {lead; usal mine; ga; rmine}
#ALIAS {u2} {usal mineb; ga}
#ALIAS {u3} {usal minec; ga}
#ALIAS {us1} {unsaddle mine}
#ALIAS {us2} {unsaddle mineb}
#ALIAS {us} {lead; us1; us2}
#ALIAS {usa} {lead; us1; u1; u2; us2}
#ALIAS {usaa} {usaa horse; usaa pony; usaa mule}
#ALIAS {unsaall} {#($powwow_at[0]=1); #WHILE {$powwow_at[0]<=9} {#NOP UNSUPPORTED: #ex ("usal \@0.$1"); #($powwow_at[0]++)}}
#ALIAS {rmine} {ride mine}
#ALIAS {sr} {stand; ride mine}
#ALIAS {r1} {#ALIAS {sr} {stand; ride mine}; #ALIAS {rmine} {ride mine}; sr}
#ALIAS {r2} {#ALIAS {sr} {stand; ride mineb}; #ALIAS {rmine} {ride mineb}; sr}
#ALIAS {r3} {#ALIAS {sr} {stand; ride minec}; #ALIAS {rmine} {ride minec}; sr}
#ALIAS {mr} {stand; ride mine; say ride}
#ALIAS {st} {stand}
#ALIAS {grm} {gr mine; gr mineb}
#ALIAS {g1} {give %1 mine}
#ALIAS {g1a} {give all.%1 mine}
#ALIAS {g1d} {give saddlebag mine}
#ALIAS {g1s} {give largesack mine}
#ALIAS {g1t} {give satchel mine}
#ALIAS {g1r} {give rope mine}
#ALIAS {g1x} {give box mine}
#ALIAS {g1b} {give backpack mine}
#ALIAS {g1w} {give web mine}
#ALIAS {g2} {give %1 mineb}
#ALIAS {g2a} {give all.%1 mineb}
#ALIAS {g2d} {give saddlebag mineb}
#ALIAS {g2s} {give largesack mineb}
#ALIAS {g2t} {give satchel mineb}
#ALIAS {g2r} {give rope mineb}
#ALIAS {g2x} {give box mineb}
#ALIAS {g2b} {give backpack mineb}
#ALIAS {g2w} {give web mineb}
#ALIAS {gd1} {u1s; drop saddlebag; g1a; get saddlebag}
#ALIAS {gd2} {u2; drop saddlebag; g2a; get saddlebag}
#ALIAS {gs1} {u1s; drop all.largesack; g1a; get all.largesack}
#ALIAS {gs2} {u2; drop all.largesack; drop web; g2a; get web; get all.largesack}
#ALIAS {gt1} {u1s; drop satchel; g1a; get satchel}
#ALIAS {gt2} {u2; drop satchel; g2a; get satchel}
#ALIAS {gw1} {u1s; drop web; g1a; get web}
#ALIAS {gw2} {u2; drop web; g2a; get web}
#ALIAS {gb1} {u1s; drop backpack; g1a; get backpack}
#ALIAS {gb2} {u2; drop backpack; g2a; get backpack}
#CLASS {sadbaggag} {OPEN}
#ACTION {It is a saddlebag.} {#LINE GAG}
#CLASS {sadbaggag} {CLOSE}
#ALIAS {ld} {look in saddlebag; con saddlebag}
#ALIAS {gd} {get %1 saddlebag}
#ALIAS {gda} {get all.%1 saddlebag}
#ALIAS {pd} {put %1 saddlebag}
#ALIAS {pda} {put all.%1 saddlebag}
#ALIAS {makecontaineraliases} {makesatch; makebp; makebpb; makepouch; makestash}
#CLASS {satchelag} {OPEN}
#ACTION {It is a leather satchel.} {#LINE GAG}
#CLASS {satchelag} {CLOSE}
#ALIAS {makesatch} {#IF {$p_backpack == "silvan"} {#VARIABLE {p_satch} {2}}; #ELSE {#VARIABLE {p_satch} {1}}; #($powwow_at[0]=1); #WHILE {$powwow_at[0]<=7} {#NOP UNSUPPORTED: #ex ("makesatch\@0"); #($powwow_at[0]++)}}
#ALIAS {makesatch1} {#NOP UNSUPPORTED: #ex ("#alias lt={look in "+$satch+".satchel; con "+$satch+".satchel}")}
#ALIAS {makesatch2} {#NOP UNSUPPORTED: #ex ("#alias gt=get \$1 "+$satch+".satchel")}
#ALIAS {makesatch3} {#NOP UNSUPPORTED: #ex ("#alias gta=get all.\$1 "+$satch+".satchel")}
#ALIAS {makesatch4} {#NOP UNSUPPORTED: #ex ("#alias pt=put \$1 "+$satch+".satchel")}
#ALIAS {makesatch5} {#NOP UNSUPPORTED: #ex ("#alias pta=put all.\$1 "+$satch+".satchel")}
#ALIAS {makesatch6} {#NOP UNSUPPORTED: #ex ("#alias gst={get all.largesack "+$satch+".satchel}")}
#ALIAS {makesatch7} {#NOP UNSUPPORTED: #ex ("#alias pst={put all.largesack "+$satch+".satchel}")}
#VARIABLE {p_backpack} {silvan}
#CLASS {backpackgag} {OPEN}
#ACTION {It is a leather backpack.} {#LINE GAG}
#CLASS {backpackgag} {CLOSE}
#CLASS {silvansatgag} {OPEN}
#ACTION {It is a silvan satchel.} {#LINE GAG}
#CLASS {silvansatgag} {CLOSE}
#ALIAS {makebp} {#($powwow_at[0]=1); #WHILE {$powwow_at[0]<=7} {#NOP UNSUPPORTED: #ex ("makebp\@0"); #($powwow_at[0]++)}}
#ALIAS {makebp1} {#NOP UNSUPPORTED: #ex ("#alias lb={look in "+$backpack+"; con "+$backpack+"}")}
#ALIAS {makebp2} {#NOP UNSUPPORTED: #ex ("#alias gb=get \$1 "+$backpack)}
#ALIAS {makebp3} {#NOP UNSUPPORTED: #ex ("#alias gba=get all.\$1 "+$backpack)}
#ALIAS {makebp4} {#NOP UNSUPPORTED: #ex ("#alias pb=put \$1 "+$backpack)}
#ALIAS {makebp5} {#NOP UNSUPPORTED: #ex ("#alias pba=put all.\$1 "+$backpack)}
#ALIAS {makebp6} {#NOP UNSUPPORTED: #ex ("#alias opbp=open "+$backpack)}
#ALIAS {makebp7} {#NOP UNSUPPORTED: #ex ("#alias clbp=close "+$backpack)}
#ALIAS {makebpb} {#IF {$p_backpack == "backpack"} {#VARIABLE {p_bpb} {2}}; #ELSE {#VARIABLE {p_bpb} {1}}; #($powwow_at[0]=1); #WHILE {$powwow_at[0]<=7} {#NOP UNSUPPORTED: #ex ("makebpb\@0"); #($powwow_at[0]++)}}
#ALIAS {makebpb1} {#NOP UNSUPPORTED: #ex ("#alias lbb={look in "+$bpb+".backpack; con "+$bpb+".backpack}")}
#ALIAS {makebpb2} {#NOP UNSUPPORTED: #ex ("#alias gbb=get \$1 "+$bpb+".backpack")}
#ALIAS {makebpb3} {#NOP UNSUPPORTED: #ex ("#alias gbba=get all.\$1 "+$bpb+".backpack")}
#ALIAS {makebpb4} {#NOP UNSUPPORTED: #ex ("#alias pbb=put \$1 "+$bpb+".backpack")}
#ALIAS {makebpb5} {#NOP UNSUPPORTED: #ex ("#alias pbba=put all.\$1 "+$bpb+".backpack")}
#ALIAS {makebpb6} {#NOP UNSUPPORTED: #ex ("#alias opbpb=open "+$bpb+".backpack")}
#ALIAS {makebpb7} {#NOP UNSUPPORTED: #ex ("#alias clbpb=close "+$bpb+".backpack")}
#VARIABLE {p_petalpouch} {sable}
