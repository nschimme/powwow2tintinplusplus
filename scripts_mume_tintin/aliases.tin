#CLASS {satchelag} {OPEN}
#ACTION {It is a leather satchel.} {#LINE GAG}
#CLASS {satchelag} {CLOSE}
#ALIAS {makesatch} {#IF {$p_backpack == silvan} {#VARIABLE {p_satch} {2}}; #ELSE {#VARIABLE {p_satch} {1}}; #MATH {p_result} {$powwow_at_0 = 1}; #WHILE {$powwow_at_0 <= 7} {#MATH {p_exe_tmp} {makesatch\@0}; #$p_exe_tmp; #MATH {p_result} {$powwow_at_0}}}
#ALIAS {makesatch1} {#MATH {p_exe_tmp} {#alias lt={look in $p_satch.satchel; con $p_satch.satchel}}; #$p_exe_tmp}
#ALIAS {makesatch2} {#MATH {p_exe_tmp} {#alias gt=get \$1 $p_satch.satchel}; #$p_exe_tmp}
#ALIAS {makesatch3} {#MATH {p_exe_tmp} {#alias gta=get all.\$1 $p_satch.satchel}; #$p_exe_tmp}
#ALIAS {makesatch4} {#MATH {p_exe_tmp} {#alias pt=put \$1 $p_satch.satchel}; #$p_exe_tmp}
#ALIAS {makesatch5} {#MATH {p_exe_tmp} {#alias pta=put all.\$1 $p_satch.satchel}; #$p_exe_tmp}
#ALIAS {makesatch6} {#MATH {p_exe_tmp} {#alias gst={get all.largesack $p_satch.satchel}}; #$p_exe_tmp}
#ALIAS {makesatch7} {#MATH {p_exe_tmp} {#alias pst={put all.largesack $p_satch.satchel}}; #$p_exe_tmp}
#VARIABLE {p_backpack} {silvan}
#CLASS {backpackgag} {OPEN}
#ACTION {It is a leather backpack.} {#LINE GAG}
#CLASS {backpackgag} {CLOSE}
