#ALIAS {usa} {lead; us1; u1; u2; us2}
#ALIAS {usaa} {usaa horse; usaa pony; usaa mule}
#ALIAS {unsaall} {#MATH {p_result} {$powwow_at_0 = 1}; #WHILE {$powwow_at_0 <= 9} {#MATH {p_exe_tmp} {usal \@0.$1}; #$p_exe_tmp; #MATH {p_result} {$powwow_at_0}}}
#ALIAS {rmine} {ride mine}
#ALIAS {sr} {stand; ride mine}
