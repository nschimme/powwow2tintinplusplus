#CLASS {converted} {OPEN}
#NOP --- POWWOW COMPATIBILITY LAYER ---
#VARIABLE {powwow_at_lines} {24}
#VARIABLE {powwow_at_mem} {0}
#VARIABLE {powwow_at_buffer} {0}
#FORMAT {powwow_start_time} {%T}
#FUNCTION {powwow_timer} {#FORMAT {now} {%T};#MATH {result} {($now - $powwow_start_time) * 1000}}
#FUNCTION {powwow_rand} {#MATH {result} {1d%1 - 1}}
#FUNCTION {powwow_char_length} {#FORMAT {result} {%x} {%1}}
#FUNCTION {powwow_search} {#FORMAT {result} {%p} {%2} {%1}}
#FUNCTION {powwow_word_count} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN &p_words[]}
#FUNCTION {powwow_word} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN $p_words[%2]}
#FUNCTION {powwow_word_slice_to_end} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[%2..-1]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_word_slice_from_start} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[1..%2]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_first_char_ascii} {#FORMAT {result} {%a} {%1}}
#FUNCTION {powwow_to_number} {#MATH {result} {%1}}
#ALIAS {powwow_reserved_echo} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#ALIAS {powwow_reserved_print} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#NOP /  I like to have a bunch of pre-prepared kits, in the satchel on my main mounts. 'lka' looks in them all, then 'wk <1-8>' selects the one you want
#ALIAS {lk} {#IF {@powwow_first_char_ascii{%0}} {look in %0.kit}}
#ELSE {look in kit}
#ALIAS {lka} {gba green; pba cup; rem kit; gda kit; lk 1; lk 2; lk 3; lk 4; lk 5; lk 6; lk 7; lk 8}
#ALIAS {wk} {wear %1.kit; pb green; pda kit; lk}
#ALIAS {pk} {put %1 kit}
#SHOWME { Herb-related aliases }
#SHOWME {  - 'pf' when at a bush, or 'ga plant' then 'cpa' to crush and auto-stash all }
#SHOWME {  - assumes you are using same aliases for storage (see aliases.txt)          }
#ALIAS {pf} {get all from all.plant; get all from all.shrub; stashbush}
#ALIAS {cp} {#IF {@powwow_first_char_ascii{%0}} {crush %0.plant}; #ELSE {crush plant}; stashcrush}
#ALIAS {cpa} {#3 crush plant; stashcrush}
#ALIAS {cpaa} {#8 crush plant; stashcrush}
#ALIAS {stashherbs} {psa weed; psba red; stashcrush; stashbush}
#ALIAS {stashcrush} {ppa leaves; ppa petals; ppa powder}
#ALIAS {stashbush} {ppa leaves; ppa berries; ppa flowers}
#CLASS {donecp} {OPEN}
#ACTION {You have} {stashcrush; #CLASS {donecp} {KILL}}
#CLASS {donecp} {CLOSE}
#ALIAS {sorth} {_sh lily 3; _sh sage 4; _sh thyme 5; _sh mauve 6; _sh rosemary 4; _sh figwort 3; _sh athelas 3; _sh marjoram 4; _sh tarragon 5; _sh cloves 8; _sh cinnamon 8; _sh poppy 2; _sh coneflower 2; _sh clover 5; _eh splayed; _eh powder; _eh foxtail; _eh foxglove; _eh honeysuckle; _eh violet}
#ALIAS {sorthh} {_shh honey-wax; _shh rib-bone; _shh moss}
#ALIAS {_shh} {gpa %1; gba %1; gda %1; #IF {$1 == honey-wax} {psca %1; gsca %1}; #ELSE {psba %1; gsba %1}; pp %1; #IF {$1 == honey-wax} {psca %1}; #ELSE {psba %1}}
#ALIAS {_sh} {gpa %1; gba %1; psa %1; gsa %1; #%2 pp %1; psa %1}
#ALIAS {_eh} {gpa %1; gba %1; #IF {$1 == violet} {psba %1}; #ELSE {psa %1}}
#ALIAS {_crushhon} {#%1 crush honeycomb; pp honey-wax; #IF {%1 > 1} {psca honey-wax; pda honey-wax}}
#ALIAS {hh} {#IF {$1 == } {_crushhon 3}}
#ELSE {_crushhon %1}
#ALIAS {hhh} {_crushhon 8}
#ALIAS {qf} {quaff %1; hide %1}
#SHOWME { These assume you've pre-made and stashed them (most of those last a while). Heavy ones in satchel on mount, light ones in backpack }
#ALIAS {see} {gb phosphorescent; qf phosphorescent}
#ALIAS {shad} {gb sombre; qf sombre}
#ALIAS {anti} {gb brown; qf brown}
#ALIAS {sooth} {utm; gt draught; qf draught; gm}
#ALIAS {clear} {utm; gt pungent; qf pungent; gm}
#SHOWME { Mixed kits }
#CLASS {nomixed} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains nothing} {#SHOWME {$0 ($p_GREEN$p_BOLDEMPTY$p_NORM)}}
#CLASS {nomixed} {CLOSE}
#CLASS {mixedwalk1} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a cluster of hard, round, black berries, a handful of clover, several cloves and a pinch of pale-green, crushed leaves} {#SHOWME {$0 ($p_BOLD$p_HERBCOLWalking$p_NORM)}}
#CLASS {mixedwalk1} {CLOSE}
#CLASS {mixedwalk2} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a pinch of pale-green, crushed leaves, a handful of clover, several cloves and a cluster of hard, round, black berries} {#SHOWME {$0 ($p_BOLD$p_HERBCOLWalking$p_NORM)}}
#CLASS {mixedwalk2} {CLOSE}
#CLASS {walkingbrew} {OPEN}
#ACTION {%1bowl of brew%2} {#SHOWME {("%1bowl of brew ("+$p_BOLD+$p_HERBCOL+"Walking"+$p_NORM+")%2")}}}
#CLASS {walkingbrew} {CLOSE}
#CLASS {mixedsooth1} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a handful of blackcurrant berries, a mashed honey-wax mixture, some grey-green leaves, some scented crushed leaves and some white petals} {#SHOWME {$0 ($p_BOLD$p_HERBCOLSoothing-draught$p_NORM)}}
#CLASS {mixedsooth1} {CLOSE}
#CLASS {mixedsooth2} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a handful of blackcurrant berries, a mashed honey-wax mixture, some grey-green leaves, some white petals and some scented crushed leaves} {#SHOWME {$0 ($p_BOLD$p_HERBCOLSoothing-draught$p_NORM)}}
#CLASS {mixedsooth2} {CLOSE}
#CLASS {soothdraught} {OPEN}
#ACTION {%1herbal draught%2} {#SHOWME {("%1herbal draught ("+$p_BOLD+$p_HERBCOL+"Soothing-draught"+$p_NORM+")%2")}}}
#CLASS {soothdraught} {CLOSE}
#CLASS {mixedshad} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a bag of cinnamon, several needlelike leaves and a rib-bone of a skeleton} {#SHOWME {$0 ($p_BOLD$p_HERBCOLShadows$p_NORM).}}
#CLASS {mixedshad} {CLOSE}
#CLASS {shadbottle} {OPEN}
#ACTION {%1sombre bottle%2} {#SHOWME {("%1sombre bottle ("+$p_BOLD+$p_HERBCOL+"Shadows"+$p_NORM+")%2")}}}
#CLASS {shadbottle} {CLOSE}
#CLASS {mixedanti} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains two piles of blackberries, some long, slender green leaves, some white petals and some grey petals} {#SHOWME {$0 ($p_BOLD$p_HERBCOLAntidote$p_NORM)}}
#CLASS {mixedanti} {CLOSE}
#CLASS {antibottle} {OPEN}
#ACTION {%1brown bottle%2} {#SHOWME {("%1brown bottle ("+$p_BOLD+$p_HERBCOL+"Antidote"+$p_NORM+")%2")}}}
#CLASS {antibottle} {CLOSE}
#CLASS {mixedseeing1} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a bag of cinnamon, a patch of phosphorescent moss and several needlelike leaves} {#SHOWME {$0 ($p_BOLD$p_HERBCOLSeeing$p_NORM).}}
#CLASS {mixedseeing1} {CLOSE}
#CLASS {mixedseeing2} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a bag of cinnamon, several needlelike leaves and a patch of phosphorescent moss} {#SHOWME {$0 ($p_BOLD$p_HERBCOLSeeing$p_NORM)}}
#CLASS {mixedseeing2} {CLOSE}
#CLASS {seebottle} {OPEN}
#ACTION {%1phosphorescent bottle%2} {#SHOWME {("%1phosphorescent bottle ("+$p_BOLD+$p_HERBCOL+"Seeing"+$p_NORM+")%2")}}}
#CLASS {seebottle} {CLOSE}
#CLASS {mixedclear} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains some sweet-smelling dried mauve petals, some grey-green leaves, some scented crushed leaves and a cluster of hard, round, black berries.} {#SHOWME {$0 ($p_BOLD$p_HERBCOLClearthought$p_NORM)}}
#CLASS {mixedclear} {CLOSE}
#CLASS {pungbrew} {OPEN}
#ACTION {%1pungent brew%2} {#SHOWME {("%1pungent brew ("+$p_BOLD+$p_HERBCOL+"Clearthought"+$p_NORM+")%2")}}}
#CLASS {pungbrew} {CLOSE}
#CLASS {mixedscaly} {OPEN}
#ACTION {A (fragrant-smelling bag|green leather bag|crude herbal kit) contains a bright red mushroom, a hemlock plant, a sticky mass of stems, leaves and sap, a foul-smelling root, some orange-red flowers and some white, egg-shaped berries} {#SHOWME {$0 ($p_BOLD$p_HERBCOLDrake-slumber$p_NORM)}}
#CLASS {mixedscaly} {CLOSE}
#CLASS {glassflask} {OPEN}
#ACTION {%1glass flask%2} {#SHOWME {("%1glass flask ("+$p_BOLD+$p_HERBCOL+"Drake-slumber"+$p_NORM+")%2")}}}
