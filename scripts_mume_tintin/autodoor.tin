#CLASS {39} {OPEN}
#ACTION {The exit %1 blurs for a while} {#SHOWME {The exit -- %1 -- \033[1m\033[32m POPPED! \033[0m}}
#CLASS {39} {CLOSE}
#CLASS {52} {OPEN}
#ACTION {The exit %1 seems to blur for a while} {#SHOWME {The exit -- %1 -- was \033[1m\033[32m BLOCKED! \033[0m}}
#CLASS {52} {CLOSE}
#CLASS {53a} {OPEN}
#ACTION {The %1 seems to blur for a while} {#SHOWME {The block on the -- %1 -- was \033[1m\033[32m BROKEN! \033[0m}}
#CLASS {53a} {CLOSE}
#CLASS {53b} {OPEN}
#ACTION {The %1 seem to blur for a while} {#SHOWME {The block on the -- %1 -- was \033[1m\033[32m BROKEN! \033[0m}}
#CLASS {53b} {CLOSE}
#SHOWME {$p_GREEN ==== autodoor.txt loaded ==== $p_NORM}
#CLASS {converted} {CLOSE}