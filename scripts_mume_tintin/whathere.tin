#CLASS {converted} {OPEN}
#NOP --- POWWOW COMPATIBILITY LAYER ---
#VARIABLE {powwow_at_lines} {24}
#VARIABLE {powwow_at_mem} {0}
#VARIABLE {powwow_at_buffer} {0}
#FORMAT {powwow_start_time} {%T}
#FUNCTION {powwow_timer} {#FORMAT {now} {%T};#MATH {result} {($now - $powwow_start_time) * 1000}}
#FUNCTION {powwow_rand} {#MATH {result} {1d%1 - 1}}
#FUNCTION {powwow_char_length} {#FORMAT {result} {%x} {%1}}
#FUNCTION {powwow_search} {#FORMAT {result} {%p} {%2} {%1}}
#FUNCTION {powwow_word_count} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN &p_words[]}
#FUNCTION {powwow_word} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN $p_words[%2]}
#FUNCTION {powwow_word_slice_to_end} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[%2..-1]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_word_slice_from_start} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[1..%2]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_first_char_ascii} {#FORMAT {result} {%a} {%1}}
#FUNCTION {powwow_to_number} {#MATH {result} {%1}}
#ALIAS {powwow_reserved_echo} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#ALIAS {powwow_reserved_print} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#SHOWME {======================================================================================================}
#SHOWME {|    Highlighting mobs vs. items in room - object/mob/friend/container etc                            }
#SHOWME {|     - a herculean project still very much in progress!                                              }
#SHOWME {|     - Would be quicked to adjust code, but then I'd not have an excuse to catalogue every beast :p  }
#SHOWME {|    Objective is to make MUME more dyslexic-friendly (ie. quick identification of stuff)             }
#SHOWME {======================================================================================================}
#SHOWME {Labelled mobs/mounts/players}
#HIGHLIGHT {$p_glowing} {white on magenta}
#HIGHLIGHT {and glowing)} {white on magenta}
#HIGHLIGHT {$p_hidden} {black on yellow}
#HIGHLIGHT {$p_shrouded} {black on yellow}
#HIGHLIGHT {[blue]} {blue}
#HIGHLIGHT {$p_blue} {blue}
#HIGHLIGHT {$p_red} {red}
#HIGHLIGHT {it glows blue} {blue}
#HIGHLIGHT {it glows red} {red}
#HIGHLIGHT {it glows purple} {magenta}
#HIGHLIGHT {$p_flawless} {green}
#HIGHLIGHT {$p_well - $p_maintained} {green}
#HIGHLIGHT {$p_satisfactory} {yellow}
#HIGHLIGHT {$p_used} {yellow}
#HIGHLIGHT {$p_worn} {red}
#HIGHLIGHT {$p_neglected} {red}
#HIGHLIGHT {$p_marred} {red}
#HIGHLIGHT {$p_unavailing} {red}
#HIGHLIGHT {$p_deteriorating} {red}
#HIGHLIGHT {$p_worn} {red}
#HIGHLIGHT {, new)} {green}
#HIGHLIGHT {, fresh)} {green}
#HIGHLIGHT {, seasoned)} {green}
#HIGHLIGHT {, well-seasoned)} {yellow}
#HIGHLIGHT {, aged)} {yellow}
#HIGHLIGHT {, old)} {yellow}
#HIGHLIGHT {, hoary)} {red}
#HIGHLIGHT {, timeworn)} {red}
#HIGHLIGHT {, age-old)} {red}
#HIGHLIGHT {, antiquated)} {red}
#NOP / Special...
#CLASS {saruman} {OPEN}
#ACTION {old man, swathed in a great light-coloured cloak} {#SHOWME {$0 $p_BKCYAN$p_DARK (Saruman)$p_NORM}}
#CLASS {saruman} {CLOSE}
#CLASS {lookaround1} {OPEN}
#ACTION {^You see some (light|smoke) to the ([a-z]+)\.} {#SHOWME {$p_BOLDYou see some $2 to the $p_YELLOW$p_CAPDIR_%3$p_NORM}}
#CLASS {lookaround1} {CLOSE}
#CLASS {fcont1} {OPEN}
#ACTION {You failed to control%1} {#SHOWME {You $p_ULINE$p_BOLD$p_MOBCOLfailed to control$p_NORM$1}}
#CLASS {fcont1} {CLOSE}
#HIGHLIGHT {You stopped training in this} {yellow}
#HIGHLIGHT {You achieved something new!} {bold green on magenta}
#NOP / Enemies, friends & special mobs
#NOP / Disabled these as were making a mess in prompt etc
#NOP / #mark *& the &*=bold red
#NOP / #mark *&Orc*=bold red
#NOP / #mark *&Troll*=bold red
#NOP / #mark *&Man*=bold red
#NOP / #mark *&Woman*=bold red
#NOP / #mark *&Elf*=bold red
#NOP / #mark *&Dwarf*=bold red
#NOP / #mark *&Hobbit*=bold red
#CLASS {whohere_e1} {OPEN}
#ACTION {*%1* is her%2.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM is her$2.); #action >+whohere_e2 *&1*, wielding &2, is her&3.=#print ($BOLD+$RED+ * %1 * +$NORM+ , $p_wielding}}
#CLASS {whohere_e1} {CLOSE}
#CLASS {whohere_em} {OPEN}
#ACTION {%1 %2 is %3ere, ridden by *%4*.} {#SHOWME {$1 $p_BOLD$p_MOBCOL$2$p_NORM is $3ere, ridden by $p_BOLD$p_RED*$4*$p_NORM}}
#CLASS {whohere_em} {CLOSE}
#NOP / brief off:
#NOP / Vehement the Man, wielding a blackened spear, is here, riding a warhorse (vehm).
#NOP / Vehement the Man, wielding a blackened spear, is standing here.
#NOP / Xarfax the Dwarf (leader), wielding the silvery broadsword, is standing here.
#NOP / Xarfax the Dwarf (leader), wielding the silvery broadsword, is here, riding a dales-pony (xarm).
#NOP / brief on:
#NOP / Xarfax the Dwarf (leader) is here, riding a dales-pony (xarm).
#NOP / Vehement the Man (veh) is here, riding a warhorse (vehm).
#NOP / Taryn the Man (leader) is standing here.
#CLASS {whohere_pg1} {OPEN}
#ACTION {^([^ ]+) the ([^ ]+) ([(][a-zA-Z]+[)])(, wielding [a-zA-Z ]+,)? is( standing)? here(.*)?\.} {#SHOWME {$p_BOLD$p_LABELCOL$2$p_NORM$p_LABELCOL the $3 $4$p_NORM$5 is$6 here$7.}}
#CLASS {whohere_pg1} {CLOSE}
#CLASS {whohere_pn2} {OPEN}
#ACTION {^([^ ]+) the ([^ ]+)(, wielding [a-zA-Z ]+,)? is( standing)? here(.*)?\.} {#SHOWME {$p_MOBCOL$2 the $3$p_NORM$4 is$5 here$6.}}
#CLASS {whohere_pn2} {CLOSE}
#CLASS {whohere_p2} {OPEN}
#ACTION {^%1 the %2, wielding %3, is standing her%4.} {#SHOWME {$p_BOLD$p_MOBCOL$1$p_NORM the $2, wielding $p_ITEMCOL$3$p_NORM, is her$4.}}
#CLASS {whohere_p2} {CLOSE}
#CLASS {whohere_p4} {OPEN}
#ACTION {^%1 the %2, wielding %3, is her%4, riding %5.} {#SHOWME {$p_BOLD$p_MOBCOL$1$p_NORM the $2, wielding $p_ITEMCOL$3$p_NORM, is her$4, riding $p_MOBCOL$5$p_NORM.}}
#CLASS {whohere_p4} {CLOSE}
#CLASS {whohere_p1} {OPEN}
#ACTION {^%1 the %2 is standing her%3.} {#SHOWME {$p_BOLD$p_MOBCOL$1$p_NORM the $2 is her$3.}}
#CLASS {whohere_p1} {CLOSE}
#CLASS {whohere_p3} {OPEN}
#ACTION {^%1 the %2 is her%3, riding %4.} {#SHOWME {$p_BOLD$p_MOBCOL$1$p_NORM the $2 is her$3, riding $p_MOBCOL$4$p_NORM.}}
#CLASS {whohere_p3} {CLOSE}
#CLASS {whohereP1} {OPEN}
#ACTION {^([a-zA-Z]+) is standing here(.*)\.} {#SHOWME {$p_MOBCOL$2$p_NORM is standing here$3.}}
#CLASS {whohereP1} {CLOSE}
#NOP / Enemies
#CLASS {whohere_e1} {OPEN}
#ACTION {^.{0,9}([[*][^*]+[*])[^ ,]{0,4}(, wielding [a-zA-Z ]+,)? is( standing)? here(.*)?\.} {#LINE GAG}
#CLASS {whohere_e1} {CLOSE}
#SHOWME {$p_ENEMYCOL$2$p_NORM$3 is$4 here$5.}
#NOP / Movement
#VARIABLE {p_CAPDIR_north} {^^^ NORTH ^^^}
#VARIABLE {p_CAPDIR_east} {>>> EAST >>>}
#VARIABLE {p_CAPDIR_south} {vvv SOUTH vvv}
#VARIABLE {p_CAPDIR_west} {<<< WEST <<<}
#VARIABLE {p_CAPDIR_up} {ooo UP ooo}
#VARIABLE {p_CAPDIR_down} {xxx DOWN xxx}
#VARIABLE {p_CAPDIR_northwest} {^^^ NORTH WEST <<<}
#VARIABLE {p_CAPDIR_northeast} {^^^ NORTH EAST >>>}
#VARIABLE {p_CAPDIR_southwest} {vvv SOUTH WEST <<<}
#VARIABLE {p_CAPDIR_southeast} {vvv SOUTH EAST >>>}
#VARIABLE {p_CAPADIR_north} {vvv NORTH vvv}
#VARIABLE {p_CAPADIR_east} {<<< EAST <<<}
#VARIABLE {p_CAPADIR_south} {^^^ SOUTH ^^^}
#VARIABLE {p_CAPADIR_west} {>>> WEST >>>}
#VARIABLE {p_CAPADIR_above} {xxx ABOVE xxx}
#VARIABLE {p_CAPADIR_below} {ooo BELOW ooo}
