#VARIABLE {p_GOBACK_east} {w}
#VARIABLE {p_GOBACK_north} {s}
#VARIABLE {p_GOBACK_south} {n}
#VARIABLE {p_GOBACK_up} {d}
#VARIABLE {p_GOBACK_west} {e}
