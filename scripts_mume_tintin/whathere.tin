#CLASS {earr1} {OPEN}
#ACTION {*%1*\033[0m %2 has arrived from the %3 riding %4.} {#SHOWME {*$1* $p_BOLD$p_RED$2$p_NORM $2 has arrived from $p_ARRIVESCOL$p_CAPADIR_%3$p_NORM riding $p_BOLD$p_MOBCOL$4$p_NORM}}
#CLASS {earr1} {CLOSE}
#CLASS {earr2} {OPEN}
#ACTION {*%1*\033[0m %2 has arrived from the %3.} {#SHOWME {*$1* $p_BOLD$p_RED$2$p_NORM $2 has arrived from $p_ARRIVESCOL$p_CAPADIR_%3$p_NORM}}
#CLASS {earr2} {CLOSE}
#CLASS {earr3} {OPEN}
#ACTION {*%1*\033[0m has arrived from the %2 riding %3.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM has arrived from $p_ARRIVESCOL$p_CAPADIR_%2$p_NORM riding $p_BOLD$p_MOBCOL$3$p_NORM}}
#CLASS {earr3} {CLOSE}
#CLASS {earr4} {OPEN}
#ACTION {*%1*\033[0m has arrived from the %2.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM has arrived from $p_ARRIVESCOL$p_CAPADIR_%2$p_NORM}}
#CLASS {earr4} {CLOSE}
#CLASS {eleaves1} {OPEN}
#ACTION {*%1*\033[0m leaves %2.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM leaves $p_LEAVESCOL$p_CAPDIR_%2$p_NORM}}
#CLASS {eleaves1} {CLOSE}
#CLASS {eleaves_riding} {OPEN}
#ACTION {*%1*\033[0m leaves %2 riding %3.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM leaves $p_LEAVESCOL$p_CAPDIR_%2$p_NORM riding $p_BOLD$p_MOBCOL}}
#CLASS {eleaves_riding} {CLOSE}
#CLASS {eleaves_sneaking} {OPEN}
#ACTION {*%1*\033[0m leaves %2 sneaking.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM leaves $p_LEAVESCOL$p_CAPDIR_%2 $p_STATUSCOLsneaking$p_NORM.}}
#CLASS {eleaves_sneaking} {CLOSE}
#CLASS {eleaves_ff} {OPEN}
#ACTION {*%1*\033[0m %2 leaves %3.} {#SHOWME {$p_BOLD$p_RED*$1*$p_NORM$2 leaves $p_LEAVESCOL$p_CAPDIR_%3$p_NORM}}
