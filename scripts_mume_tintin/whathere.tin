#ACTION {^%1 %2 suddenly leaves its place%3} {#SHOWME {$1 $p_BOLD$p_MOBCOL$2 $p_NORM$p_ULINEsuddenly leaves its place$3$p_NORM}}
#CLASS {leaves_hiding2} {CLOSE}
#CLASS {found_hiding1} {OPEN}
#ACTION {^You found %1 %2!} {#SHOWME {$p_NORM$p_ULINEYou found $1 $p_BOLD$p_MOBCOL$2$p_NORM!}}
