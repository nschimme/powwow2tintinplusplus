#NOP /  Some custom emotes
#ALIAS {.} {emote %0.}
#ALIAS {nodh} {emote nods happily.}
#ALIAS {wrink} {emote wrinkles her nose in distaste.}
#ALIAS {rubglee} {emote rubs her hands together gleefully.}
#ALIAS {shud} {emote shudders, a chill running down her spine.}
#ALIAS {mumb} {emote mumbles, '%0', in her sleep.}
#NOP / Helpful AFKness
#VARIABLE {p_afkact} {staring off into the distance (afk)}
#VARIABLE {p_Xafkact} {striking a pose (afk)}
#VARIABLE {powwow_at_afk} {0}
#ALIAS {setqt} {#ALIAS {qt} {tell %1 %%0}; #TAB {%1}}
#ALIAS {qt} {tell XXXX %0}
#CLASS {afk} {OPEN}
#ACTION {m([^ ]+) tells you .+} {#IF {!$powwow_at_autoreplied_%2} {tell $2 I'm either AFK or otherwise distracted. Please leave a message and I'll get back to you. :); #VARIABLE {powwow_at_autoreplied_$2} {1}}; setqt %2}
#CLASS {afk} {CLOSE}
#ALIAS {back} {asoff; #CLASS {afk} {KILL}; #CLASS {tell1} {OPEN}; cha title $p_chartitle; act; emote livens up a bit, smiles, and says 'Back!'; #VARIABLE {powwow_at_afk} {0}}
#ALIAS {afk} {#CLASS {afk} {OPEN}; #CLASS {tell1} {KILL}; #IF {$0 != } {cha title %0}; #ELSE {cha title is distracted, please leave a massage}; act $p_afkact; #VARIABLE {powwow_at_afk} {1}}
#VARIABLE {p_lfgtitle} { - LFG for XP/smobs/Moria!}
#ALIAS {lfg} {cha title $p_lfgtitle; #VARIABLE {p_title} {$p_lfgtitle}}
#ALIAS {lfgoff} {cha title $p_chartitle; #VARIABLE {p_title} {$p_chartitle}}
#NOP /  Communications - come first to avoid confusion when people past stuff into narrates
#CLASS {tellfix1} {OPEN}
#ACTION {inner voice} {}
#CLASS {tellfix1} {CLOSE}
#CLASS {namedtell} {OPEN}
#ACTION {^(.*)?(Angdil|Barliman|Ecthelion|Erienal|Sarion|Erestor|Ciryariel|Daegil|Galadriel|Curundil|Sauron) tells you (.+)\.} {#SHOWME {$p_MOBCOL $3 $p_NORMtells you $p_GREEN$4$p_NORM}}
#CLASS {namedtell} {CLOSE}
#CLASS {specialtellM1} {OPEN}
#ACTION {%1 Morgoth tells you %2} {#SHOWME {$1$p_MOBCOL  Morgoth $p_NORMtells you $p_GREEN$2$p_NORM}}
#CLASS {specialtellM1} {CLOSE}
#CLASS {mobsay1} {OPEN}
#ACTION {m(The|An|A) ([a-zA-Z ,\'\-]+) (tells you|says|asks you|whispers to you) (.+)} {#SHOWME {$2 $p_MOBCOL$3$p_NORM $4 $p_GREEN$5$p_NORM}}
#CLASS {mobsay1} {CLOSE}
#CLASS {mobsay2} {OPEN}
#ACTION {m([a-zA-Z ,\'\-]+) the ([a-zA-Z -']+) (tells you|says|asks you|whispers to you) (.+)} {#SHOWME {$p_MOBCOL$2 the $3$p_NORM $4 $p_GREEN$5$p_NORM}}
#CLASS {mobsay2} {CLOSE}
#CLASS {tell1} {OPEN}
#ACTION {m%1 tells you %2} {#SHOWME {   $p_BOLD$p_BKBLUE  $1$p_NORM$p_BKBLUE tells you $p_BOLD$p_GREEN$2$p_NORM}; setqt %1}
#CLASS {tell1} {CLOSE}
#CLASS {tell2} {OPEN}
#ACTION {The voice of %1 whispers to you %2} {#SHOWME {   $p_BOLD$p_BKBLUE  The voice of $p_ULINE$1$p_NORM$p_BKBLUE$p_BOLD whispers to you $p_BOLD$p_GREEN$2$p_NORM}; setqt %1}
#CLASS {tell2} {CLOSE}
#CLASS {tellg} {OPEN}
#ACTION {m%1 tells the group %2} {#SHOWME {   $p_BOLD$p_ULINE$p_BKBLUE  $1$p_NORM$p_ULINE$p_BKBLUE tells the group $p_BOLD$p_GREEN$2$p_NORM}}
#CLASS {tellg} {CLOSE}
#CLASS {narsty} {OPEN}
#ACTION {^^%1 narrates %2 swearword %3} {#SHOWME {$p_BKBLUE$p_GREEN  $1$p_NORM$p_BKBLUE narrates $p_NORM$p_BKBLUE$p_YELLOW$2 flowers $3$p_NORM}}
#CLASS {narsty} {CLOSE}
#CLASS {nar1} {OPEN}
#ACTION {m%1 narrates %2} {#SHOWME {$p_BKBLUE$p_GREEN  $1$p_NORM$p_BKBLUE narrates $p_NORM$p_BKBLUE$p_YELLOW$2$p_NORM}}
#CLASS {nar1} {CLOSE}
#CLASS {sing1} {OPEN}
#ACTION {m%1 sings %2} {#SHOWME {$p_BKBLUE$p_GREEN  $1$p_NORM$p_BKBLUE sings $p_NORM$p_BKBLUE$p_YELLOW$2$p_NORM}}
#CLASS {sing1} {CLOSE}
#CLASS {beep1} {OPEN}
#ACTION {^([\w+]) beeps you\!} {#SHOWME {        $p_BKRED$p_CYAN*******************************$p_NORM}; #SHOWME {        $p_BKRED$p_CYAN*       !! BEEPS YOU !!       *$p_NORM}; #SHOWME {        $p_BKRED$p_CYAN*******************************$p_NORM}}
#CLASS {beep1} {CLOSE}
#ALIAS {gratzon} {#CLASS {autogratz1} {OPEN}; #CLASS {autogratz2} {OPEN}; #CLASS {autogratz3} {OPEN}; #CLASS {autogratz4} {OPEN}}
#ALIAS {gratzoff} {#CLASS {autogratz1} {KILL}; #CLASS {autogratz2} {KILL}; #CLASS {autogratz3} {KILL}; #CLASS {autogratz4} {KILL}}
#CLASS {autogratz1} {OPEN}
#ACTION {m([A-Z][a-z]+)[^\s+] narrates 'level(\!|\.)?'} {nar Wow, yeah, well done, um... whatever your name was! [automated felicitations brought to you by GrumpyGratz (tm)]}
#CLASS {autogratz1} {CLOSE}
#CLASS {autogratz2} {OPEN}
#ACTION {m([A-Z][a-z]+)[^\s+] narrates 'Level(\!|\.)?'} {nar woo, $2 has another level. *yawn* [automated felicitations brought to you by GrumpyGratz (tm)]}
#CLASS {autogratz2} {CLOSE}
#CLASS {autogratz3} {OPEN}
#ACTION {m([A-Z][a-z]+)[^\s+] narrates 'ding} {nar Go on, rub it in you little squirt, $2. Some of us have to work for our levels you know! [automated felicitations brought to you by GrumpyGratz (tm)]}
#CLASS {autogratz3} {CLOSE}
#CLASS {autogratz4} {OPEN}
#ACTION {m([A-Z][a-z]+)[^\s+] narrates 'Ding} {nar Ding off $2 or I'll dong you! [automated felicitations brought to you by GrumpyGratz (tm)]}
#CLASS {autogratz4} {CLOSE}
