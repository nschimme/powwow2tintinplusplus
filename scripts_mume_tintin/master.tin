#CLASS {converted} {OPEN}
#NOP --- POWWOW COMPATIBILITY LAYER ---
#VARIABLE {powwow_at_lines} {24}
#VARIABLE {powwow_at_mem} {0}
#VARIABLE {powwow_at_buffer} {0}
#FORMAT {powwow_start_time} {%T}
#FUNCTION {powwow_timer} {#FORMAT {now} {%T};#MATH {result} {($now - $powwow_start_time) * 1000}}
#FUNCTION {powwow_rand} {#MATH {result} {1d%1 - 1}}
#FUNCTION {powwow_char_length} {#FORMAT {result} {%x} {%1}}
#FUNCTION {powwow_search} {#FORMAT {result} {%p} {%2} {%1}}
#FUNCTION {powwow_word_count} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN &p_words[]}
#FUNCTION {powwow_word} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #RETURN $p_words[%2]}
#FUNCTION {powwow_word_slice_to_end} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[%2..-1]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_word_slice_from_start} {#LIST {p_words} {EXPLODE} { }; #LIST {p_words} {FILTER} {{.+}}; #LIST {p_slice} {CREATE} {$p_words[1..%2]}; #LIST {p_slice} {COLLAPSE} { }; #RETURN $p_slice}
#FUNCTION {powwow_first_char_ascii} {#FORMAT {result} {%a} {%1}}
#FUNCTION {powwow_to_number} {#MATH {result} {%1}}
#ALIAS {powwow_reserved_echo} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#ALIAS {powwow_reserved_print} {#IF {"%1" == ""} {#LINE PRINT} {#ELSE} {#SHOWME {%1}}}
#NOP UNSUPPORTED: #savefile-version 1
#ALIAS
#NOP /=#(0)'
#NOP /  ======================================================================================================
#NOP /  |                                                                                                    |
#NOP /  |                Master config for powwow/powtty - loads other config files                          |
#NOP /  |                                                                                                    |
#NOP /  |      - This still needs to be factored significantly and has a lot of 'Kate custom' stuff in it    |
#NOP /  |      - Also still quite buggy. Use selectively!                                                    |
#NOP /  |                                                                                                    |
#NOP /  ======================================================================================================
#NOP UNSUPPORTED: #host localhost 4242
#NOP UNSUPPORTED: #delim normal
#NOP UNSUPPORTED: #groupdelim @
#VARIABLE {powwow_at_mem} {10485760}
#NOP OPTION ignored: #option -info
#SHOWME {Annoyingly it seems to need explicit path on Mac, so you'll need to change this}
#VARIABLE {p_cwd} {/Users/khcw/Games/MUME/}
#ALIAS {reload} {#READ {/Users/khcw/Games/MUME/master.txt}}
#NOP / Don't save the config file every time
#NOP UNSUPPORTED: #file =
#NOP /  Colour definitions
#VARIABLE {p_NORM} {\033[0m}
#VARIABLE {p_BOLD} {\033[1m}
#VARIABLE {p_DARK} {\033[2m}
#VARIABLE {p_ULINE} {\033[4m}
#VARIABLE {p_FLASH} {\033[5m}
#VARIABLE {p_BLACK} {\033[30m}
#VARIABLE {p_WHITE} {\033[37m}
#VARIABLE {p_RED} {\033[31m}
#VARIABLE {p_GREEN} {\033[32m}
#VARIABLE {p_BLUE} {\033[34m}
#VARIABLE {p_MAGENTA} {\033[35m}
#VARIABLE {p_CYAN} {\033[36m}
#VARIABLE {p_YELLOW} {\033[33m}
#VARIABLE {p_BKBLACK} {\033[40m}
#VARIABLE {p_BKWHITE} {\033[47m}
#VARIABLE {p_BKBLUE} {\033[44m}
#VARIABLE {p_BKCYAN} {\033[46m}
#VARIABLE {p_BKGREEN} {\033[42m}
#VARIABLE {p_BKMAGENTA} {\033[45m}
#VARIABLE {p_BKRED} {\033[41m}
#VARIABLE {p_BKYELLOW} {\033[43m}
#SHOWME { Colour customisations - these can be set to whatever you like }
#VARIABLE {p_EXITSCOL} {$p_BLUE}
#VARIABLE {p_ITEMCOL} {$p_CYAN}
#VARIABLE {p_HERBCOL} {$p_CYAN}
#VARIABLE {p_WEATHERCOL} {$p_DARK$p_BOLD$p_CYAN}
#VARIABLE {p_KEYCOL} {$p_DARK$p_CYAN$p_BOLD}
#VARIABLE {p_MOBCOL} {$p_YELLOW}
#VARIABLE {p_ENEMYCOL} {$p_BOLD$p_RED}
#VARIABLE {p_LABELCOL} {$p_GREEN}
#VARIABLE {p_STATUSCOL} {$p_BKYELLOW$p_BLACK}
#VARIABLE {p_ARRIVESCOL} {$p_MAGENTA}
#VARIABLE {p_LEAVESCOL} {$p_GREEN}
#VARIABLE {p_BASHCOL} {$p_BLUE}
#VARIABLE {p_MAGICCOL} {$p_MAGENTA}
#VARIABLE {p_TELLCOL} {$p_GREEN}
#NOP /  Need to override MUME's colours for some of the pattern matching. This was before I worked out how to get regexps working, so apologies for crudeness!
cha col look bold underline green
#NOP / This will get overridden for (unnamed) mobs
cha col say blue on green
#NOP / To also catch custom say-emotes
cha col emote blue on green
#NOP / This needs to come before highlighting - put into a file?
#ALIAS {drinkon} {#CLASS {autodrink1} {OPEN}; #CLASS {autodrink2} {OPEN}; #CLASS {autodrink3} {OPEN}; #CLASS {autodrink4} {OPEN}; #NOP UNCONVERTED ACTION ARGS: +autodrink5 message Autodrink ON}
#ALIAS {drinkoff} {#CLASS {autodrink1} {KILL}; #CLASS {autodrink2} {KILL}; #CLASS {autodrink3} {KILL}; #CLASS {autodrink4} {KILL}; #CLASS {autodrink5} {KILL}; message Autodrink OFF}
#CLASS {autodrink1} {OPEN}
#ACTION {clear spring babbles} {drink water}
#CLASS {autodrink1} {CLOSE}
#CLASS {autodrink2} {OPEN}
#ACTION {^A %1fountain} {drink water}
#CLASS {autodrink2} {CLOSE}
#CLASS {autodrink3} {OPEN}
#ACTION {inviting you to take a refreshing} {drink water}
#CLASS {autodrink3} {CLOSE}
#CLASS {autodrink4} {OPEN}
#ACTION {sparkling clear water} {drink water}
#CLASS {autodrink4} {CLOSE}
#CLASS {autodrink5} {OPEN}
#ACTION {^A %1stone well} {drink water}
#CLASS {autodrink5} {CLOSE}
#NOP / Notifications
#ALIAS {notify} {#SHOWME {$p_BLUE  %0$p_NORM}}
#ALIAS {message} {#SHOWME {}; #SHOWME {$p_BOLD$p_BLUE   --> %0 <--$p_NORM}; #SHOWME {}}
#ALIAS {warning} {#SHOWME {}; #SHOWME {$p_BOLD$p_RED   --> %0 <--$p_NORM}; #SHOWME {}}
#ALIAS {system} {#SHOWME {}; #SHOWME {$p_BKYELLOW$p_BOLD$p_BLUE   --> %0 <--$p_NORM}; #SHOWME {}}
#NOP /  Load in sub-files
#NOP /  this didn't work: #exe ("<"+$cwd+"aliases.txt") etc ")
#READ {/Users/khcw/Games/MUME/aliases.txt}
