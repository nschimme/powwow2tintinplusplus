#READ {/Users/khcw/Games/MUME/autotravel.txt}
#READ {/Users/khcw/Games/MUME/autodoor.txt}
#READ {/Users/khcw/Games/MUME/keys.txt}
#READ {/Users/khcw/Games/MUME/whathere.txt}
