#ALIAS {kremsub2} {#VARIABLE {powwow_dollar_m12} {}; #MATH {p_result} {$powwow_at_1 = 1}; #WHILE {$powwow_at_1 <= (@powwow_word_count{$powwow_dollar_m10})} {#IF {@powwow_word{$powwow_dollar_m10;$powwow_at_1} != $powwow_dollar_m11} {#VARIABLE {powwow_dollar_m12} {$powwow_dollar_m12 (@powwow_word{$powwow_dollar_m10;$powwow_at_1})}}; #MATH {p_result} {$powwow_at_1}}}
