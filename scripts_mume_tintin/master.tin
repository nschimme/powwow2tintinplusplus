#ALIAS {mapon} {#MACRO {KP8} {_mapnorth}; #MACRO {KP6} {_mapeast}; #MACRO {KP4} {_mapwest}; #MACRO {KP2} {_mapsouth}; #MACRO {KP9} {_mapup}; #MACRO {KP3} {_mapdown}}
