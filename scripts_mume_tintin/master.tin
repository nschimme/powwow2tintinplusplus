#ALIAS {checkdate} {#IF {$p_checkmonth == Foreyule} {#VARIABLE {powwow_at_dawn} {7}; #VARIABLE {powwow_at_night} {7}}; #IF {$p_checkmonth == Astron} {#VARIABLE {powwow_at_dawn} {7}; #VARIABLE {powwow_at_night} {7}}; #IF {$p_checkmonth == Thrimidge} {#VARIABLE {powwow_at_dawn} {7}; #VARIABLE {powwow_at_night} {8}}; #IF {$p_checkmonth == Forelithe} {#VARIABLE {powwow_at_dawn} {6}; #VARIABLE {powwow_at_night} {8}}; #IF {$p_checkmonth == Afterlithe} {#VARIABLE {powwow_at_dawn} {5}; #VARIABLE {powwow_at_night} {9}}; #IF {$p_checkmonth == Wedmath} {#VARIABLE {powwow_at_dawn} {4}; #VARIABLE {powwow_at_night} {10}}; #IF {$p_checkmonth == Halimath} {#VARIABLE {powwow_at_dawn} {5}; #VARIABLE {powwow_at_night} {9}}; #IF {$p_checkmonth == Winterfilth} {#VARIABLE {powwow_at_dawn} {6}; #VARIABLE {powwow_at_night} {8}}; #IF {$p_checkmonth == Blotmath} {#VARIABLE {powwow_at_dawn} {7}; #VARIABLE {powwow_at_night} {8}}; #IF {$p_checkmonth == Afteryule} {#VARIABLE {powwow_at_dawn} {8}; #VARIABLE {powwow_at_night} {6}}; #IF {$p_checkmonth == Solmath} {#VARIABLE {powwow_at_dawn} {9}; #VARIABLE {powwow_at_night} {5}}; #IF {$p_checkmonth == Rethe} {#VARIABLE {powwow_at_dawn} {8}; #VARIABLE {powwow_at_night} {6}}; printdate}
#ALIAS {kadd} {#VARIABLE {powwow_dollar_m10} {$powwow_dollar_m10 %1}; #SHOWME {%% <039>New portlocation: <119>$1<099>}; #VARIABLE {p_key_$1} {$p_latestkey}}
#ALIAS {kadd0} {#MATH {powwow_at_m10} {0}; #MATH {powwow_dollar_m11} {%1}; kremsub1; #IF {$powwow_at_m10 != 0} {#SHOWME {%% <039>Location <119>$powwow_dollar_m11<099><039> exist. Replacing it<099>}; krem %1; kadd %1}; #ELSE {kadd %1}}
